/* ── Mobile ── */
@media only screen and (max-width:520px) {

  /* Shell */
  table.shell  { width:100% !important; }

  /* Hero text - no longer needed (caption removed) */

  /* Social top row - no longer needed (always stacked now) */
  td.sec { padding:24px 16px 28px !important; }

